{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "InstaKeys – Instagram Keyboard Scrolling & Like Shortcuts",
  "version": "1.0.0",
  "description": "Scroll Instagram posts with arrow keys and like posts instantly using your keyboard.",
  "permissions": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}